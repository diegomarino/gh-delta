#!/usr/bin/env bash
# gh-delta → Orca coordinator relay (generic; cron-driven, deterministic).
#
# Bridges gh-delta's detection to a Claude-Code coordinator running in an Orca
# terminal: one tick detects GitHub deltas (PR/issue comments, reviews, CI
# flips, state changes); on deltas, a one-line summary is typed into the
# coordinator's TUI so the *agent* decides what to do (gh-delta stays a dumb
# detector; scheduling belongs to the caller — see docs/architecture.md).
#
# Everything is derived from the git repo it is pointed at:
#   checkout   <- $1 or $PWD (must be the repo's MAIN checkout: the coordinator
#                 terminal is found by matching this exact worktree path)
#   repo       <- origin remote (owner/name)
#   monitor-id <- <repo-name>-orca (scopes the gh-delta snapshot)
#
# State lives in /tmp BY DESIGN (override: GH_DELTA_RELAY_STATE):
#   - After a reboot there is no coordinator terminal to relay to, and a fresh
#     coordinator's session-start canon re-sweeps PR/issue ground truth anyway,
#     so the correct post-reboot behavior is a silent baseline re-seed — which
#     /tmp gives for free. Persisting the snapshot would only produce a delta
#     flood into a dropped log.
#   - While cron runs, ticks touch the snapshot every interval, so periodic
#     /tmp cleanup never reaps it mid-flight.
#
# No coordinator running -> deltas are logged and dropped (never a cron error).
#
# Install:
#   ln -s <this file> ~/.local/bin/gh-delta-orca-relay && chmod +x <this file>
# Cron (one line per project):
#   */2 * * * * $HOME/.local/bin/gh-delta-orca-relay /path/to/main-checkout
set -uo pipefail
export PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin

CHECKOUT=$(git -C "${1:-$PWD}" rev-parse --show-toplevel 2>/dev/null) || {
  echo "gh-delta-orca-relay: not a git repo: ${1:-$PWD}" >&2; exit 1; }
REPO=$(git -C "$CHECKOUT" remote get-url origin 2>/dev/null \
  | sed -E 's#.*[:/]([^/]+/[^/.]+)(\.git)?$#\1#')
[ -n "$REPO" ] || { echo "gh-delta-orca-relay: no origin remote in $CHECKOUT" >&2; exit 1; }
MONITOR_ID="${REPO#*/}-orca"
STATE="${GH_DELTA_RELAY_STATE:-/tmp/gh-delta-relay-$USER}"
LOG=$STATE/relay-${REPO#*/}.log
mkdir -p "$STATE"

OUT=$(node "$HOME/Dev/gh-delta/gh-delta.mjs" \
  --repo "$REPO" --monitor-id "$MONITOR_ID" \
  --state-dir "$STATE" --entities pr,issue --format text 2>>"$LOG")
CODE=$?

TS=$(date '+%F %T')
case "$CODE" in
  0) echo "$TS ok no-delta ($REPO)" >>"$LOG"; exit 0 ;;
  1) echo "$TS ERROR transient gh-delta failure ($REPO); next tick retries" >>"$LOG"; exit 0 ;;
  2) echo "$TS ERROR PERMANENT gh-delta config/snapshot error ($REPO): fix the relay flags or state dir; this refires every tick until fixed" >>"$LOG"; exit 0 ;;
  10) : ;; # deltas: fall through to the relay below
  *) echo "$TS ERROR unexpected gh-delta exit $CODE ($REPO)" >>"$LOG"; exit 0 ;;
esac

SUMMARY=$(echo "$OUT" | tr '\n' ' | ' | tr -s ' ' | cut -c1-600)
H=$(orca terminal list --json 2>/dev/null | jq -r --arg p "$CHECKOUT" \
  '.result.terminals[] | select(.worktreePath == $p) | select(.title | test("coordinator|claude";"i")) | .handle' | head -1)

if [ -z "$H" ]; then
  echo "$TS DELTA (no coordinator terminal, dropped): $SUMMARY" >>"$LOG"
  exit 0
fi

orca terminal send --terminal "$H" --enter --text "(gh-delta relay, automated) GitHub changed since last tick: $SUMMARY -- Triage per brief: if this includes new PR review comments/threads, answer+resolve them (ground-truth verified) before packaging any merge gate; ignore deltas caused by your own just-posted comments." >>"$LOG" 2>&1
echo "$TS DELTA relayed to $H: $SUMMARY" >>"$LOG"
